# GuardAgent Control Plane - Environment Variables
# Copy to .env and fill in your values

# ========== OpenAI GPT-5.6 Reasoning Engine ==========
# Get your API key from: https://platform.openai.com/api/keys
# Fallback chain: gpt-5.6 → gpt-5.1 → gpt-5 → gpt-5-mini
OPENAI_API_KEY=sk-proj-
OPENAI_MODEL=gpt-5.6

# Fix-engine temperature (lower = more deterministic patches)
# Default: 0.2 (very deterministic)
# OPENAI_FIX_TEMPERATURE=0.2

# ========== GitLab/GitHub Webhook Verification ==========
# Generate webhook secret: use a 32+ char random string or your platform's generator
# Format: GitHub: prefixed with "github_"; GitLab: prefixed with "whsec_"
GITLAB_WEBHOOK_SECRET=whsec_replace_me

# ========== Deterministic Analyzer Settings ==========
# Entropy threshold for secret detection (0-8, default 4.5)
# GUARDAGENT_ENTROPY_THRESHOLD=4.5

# Exclude patterns from scanning (comma-separated or file path)
# GUARDAGENT_EXCLUDE=**/*.lock,**/node_modules/**,.git/**

# ========== Persistence & Database ==========
# SQLite database location (absolute path or relative to backend/)
# Default: ./audit.db (created in backend/ directory)
# GUARDAGENT_DB=/data/guardagent.db

# ========== Server Configuration ==========
# Port to run the FastAPI backend on
PORT=8147

# CORS origins (space-separated)
# GUARDAGENT_CORS_ORIGINS=http://localhost:3000 http://127.0.0.1:5173

# ========== Offline Mode ==========
# When no OPENAI_API_KEY is set, the system runs in deterministic-fallback:
#  - Analyzes against 148 deterministic rules
#  - Uses hardcoded verdicts instead of GPT-5.6 reasoning
#  - Useful for demos, testing, air-gapped environments
# GUARDIAN_REASONER=offline
